# =============================================================================
# Post Fiat Validator Monitor — Environment Configuration
# =============================================================================
# Copy to .env and fill in your values:
# cp .env.example .env && nano .env
# =============================================================================

# ── postfiatd connection ──────────────────────────────────────────
# JSON-RPC URL of your postfiatd node
POSTFIATD_RPC_URL=http://host.docker.internal:5005

# Admin RPC URL (same as above unless you have a separate admin port)
# Leave empty to default to POSTFIATD_RPC_URL
POSTFIATD_ADMIN_RPC_URL=

# Path to your postfiatd config directory (mounted read-only for integrity checks)
POSTFIATD_CONFIG_DIR=/opt/postfiatd

# ── Grafana ───────────────────────────────────────────────────────
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=postfiat

# ── Prometheus ────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=30d

# ── Alertmanager ──────────────────────────────────────────────────
ALERTMANAGER_PORT=9093

# ── Discord Webhook (for alerts) ──────────────────────────────────
# Create a webhook in your Discord server → Server Settings → Integrations
# Append /slack to the URL for Alertmanager Slack-compatible mode
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/ID/TOKEN/slack
